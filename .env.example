# Banco de dados (Postgres via Supabase)
# DATABASE_URL: pooler em modo transaction (porta 6543) — usado pela aplicação em runtime.
# DIRECT_URL: conexão direta (porta 5432) — usada só pelo Prisma Migrate e pelo pg_dump do backup.
# Pegue as duas em Project Settings > Database > Connect > ORM (Prisma) no painel do Supabase.
DATABASE_URL="postgresql://postgres.SEU-PROJECT-REF:[SUA-SENHA]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.SEU-PROJECT-REF:[SUA-SENHA]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Servidor
PORT=3000
NODE_ENV=development

# Sessão (gere um valor aleatório forte em produção, ex: openssl rand -hex 32)
SESSION_SECRET=troque-este-valor-em-producao

# Semeadura de dados de demonstração — NUNCA true em produção
SEED_DEMO_DATA=true

# IA (chat)
ANTHROPIC_API_KEY=

# URL pública do deploy (sem barra no final) — usada pra montar links
# absolutos em canais sem navegador, como o .ics enviado por WhatsApp.
PUBLIC_BASE_URL=

# WhatsApp Cloud API (Meta) — veja o guia de configuração no painel da Meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# WhatsApp Embedded Signup (conexão self-service por barbearia) — WHATSAPP_APP_ID
# e WHATSAPP_CONFIG_ID vêm do App Dashboard da Meta (Embedded Signup configuration).
# WHATSAPP_TOKEN_ENCRYPTION_KEY: gere com `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
WHATSAPP_APP_ID=
WHATSAPP_CONFIG_ID=
WHATSAPP_TOKEN_ENCRYPTION_KEY=

# Painel de administração da plataforma (super-admin) — gere o hash com
# `npx tsx scripts/hash-password.ts <senha>` e cole o resultado aqui, nunca
# a senha em texto puro.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Push notifications (web-push VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@example.com

# Backup off-site (S3-compatível, opcional)
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_REGION=auto

# Monitoramento de erro (Sentry, opcional) — sem isso, erros só aparecem nos
# logs do Vercel e ninguém é avisado até o cliente reclamar.
SENTRY_DSN=

# Cobrança (Stripe, opcional) — sem isso, a aba de Cobrança fica só
# informativa (mostra status do trial, sem botão de assinar).
# STRIPE_PRICE_STARTER / STRIPE_PRICE_PRO: rode
# `npx tsx --env-file=.env scripts/setup-stripe-products.ts` depois de
# configurar STRIPE_SECRET_KEY, ele cria os planos e imprime os IDs.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
