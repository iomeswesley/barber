{
  "framework": null,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "includeFiles": "webroot/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/api/cron/reminders", "schedule": "0 11 * * *" }
  ]
}
