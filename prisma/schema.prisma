// Schema Prisma — modelo de dados multi-tenant para a plataforma.
//
// Convenção de isolamento de tenant: toda tabela que pertence a uma barbearia
// tem uma coluna `barbershopId` com índice. `Client` é a única entidade global
// (identificada pelo telefone, como no WhatsApp), e seu vínculo com uma
// barbearia específica é verificado via existência de Appointment — igual ao
// comportamento original em barbearia-bot/src/db.js (clientBelongsToShop).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooler em modo transaction (porta 6543) — usado pela aplicação em runtime.
  url       = env("DATABASE_URL")
  // Conexão direta / pooler em modo session (porta 5432) — usada só pelo
  // Prisma Migrate, que precisa de recursos (prepared statements, advisory
  // locks) que o modo transaction do pgbouncer não suporta.
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  owner
  barber
}

enum AppointmentStatus {
  confirmed
  cancelled
  no_show
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
}

enum ClientPlanBenefitType {
  services_included
  percent_discount
  unlimited_service
}

enum ClientPlanSubscriptionStatus {
  active
  past_due
  canceled
}

model Barbershop {
  id                    Int      @id @default(autoincrement())
  name                  String
  address               String?
  phone                 String?
  // ID numérico que a Meta atribui ao número de telefone do WhatsApp
  // Business (Cloud API) dessa barbearia — usado pra rotear mensagens
  // recebidas no webhook pra barbearia certa (um número por barbearia).
  whatsappPhoneNumberId String?  @unique @map("whatsapp_phone_number_id")
  createdAt             DateTime @default(now()) @map("created_at")

  // Stripe Connect (Standard) — recebimento das assinaturas que a barbearia
  // vende pros próprios clientes finais (feature separada do billing da
  // plataforma). Onboard feito pelo dono direto no Stripe; `stripeConnectOnboarded`
  // só vira true quando o webhook confirma charges_enabled + payouts_enabled.
  stripeConnectAccountId String? @unique @map("stripe_connect_account_id")
  stripeConnectOnboarded Boolean @default(false) @map("stripe_connect_onboarded")

  barbers                 Barber[]
  services                Service[]
  appointments            Appointment[]
  users                   User[]
  timeBlocks              TimeBlock[]
  reviews                 Review[]
  products                Product[]
  productSales            ProductSale[]
  auditLogs               AuditLog[]
  businessHours           BusinessHours[]
  escalations             Escalation[]
  pushSubscriptions       PushSubscription[]
  subscription            Subscription?
  clientPlans             ClientPlan[]
  clientPlanSubscriptions ClientPlanSubscription[]

  @@map("barbershops")
}

model Barber {
  id                Int     @id @default(autoincrement())
  barbershopId      Int     @map("barbershop_id")
  name              String
  active            Boolean @default(true)
  commissionPercent Decimal @default(40) @map("commission_percent") @db.Decimal(5, 2)
  monthlyGoalCents  Int     @default(0) @map("monthly_goal_cents")

  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id])
  appointments Appointment[]
  users        User[]
  timeBlocks   TimeBlock[]
  reviews      Review[]

  @@index([barbershopId])
  @@map("barbers")
}

model Service {
  id           Int     @id @default(autoincrement())
  barbershopId Int     @map("barbershop_id")
  name         String
  priceCents   Int     @map("price_cents")
  durationMin  Int     @map("duration_min")
  active       Boolean @default(true)

  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id])
  appointments Appointment[]
  clientPlans  ClientPlan[]

  @@index([barbershopId])
  @@map("services")
}

// Global — não tem barbershopId. O vínculo com uma barbearia é feito via
// Appointment (ver clientBelongsToShop no service layer).
model Client {
  id             Int       @id @default(autoincrement())
  name           String
  phone          String    @unique
  birthday       DateTime? @db.Date
  // Consentimento pra receber mensagens de marketing (ex: "reconquista" de
  // cliente sumido) — a Meta exige opt-in explícito pra esse tipo de
  // mensagem, diferente de lembrete/aviso transacional. Marcado como true
  // quando o cliente confirma um agendamento (o bot avisa nesse momento).
  marketingOptIn Boolean   @default(false) @map("marketing_opt_in")

  appointments            Appointment[]
  reviews                 Review[]
  productSales            ProductSale[]
  escalations             Escalation[]
  clientPlanSubscriptions ClientPlanSubscription[]

  @@map("clients")
}

model Appointment {
  id               Int               @id @default(autoincrement())
  barbershopId     Int               @map("barbershop_id")
  barberId         Int               @map("barber_id")
  serviceId        Int               @map("service_id")
  clientId         Int               @map("client_id")
  date             DateTime          @db.Date
  startTime        String            @map("start_time")
  endTime          String            @map("end_time")
  status           AppointmentStatus @default(confirmed)
  reminderSentAt   DateTime?         @map("reminder_sent_at")
  reviewPromptedAt DateTime?         @map("review_prompted_at")
  createdAt        DateTime          @default(now()) @map("created_at")

  // Preço efetivamente cobrado quando um plano de assinatura do cliente foi
  // aplicado (desconto ou benefício incluído) — null significa "preço de
  // tabela normal", lido em tempo de leitura via Service.priceCents
  // (toAppointmentDTO). planCreditConsumed só é true pro benefício
  // services_included, e é o que diz pro cancelamento se deve devolver a
  // cota consumida na ClientPlanSubscription.
  priceChargedCents        Int?    @map("price_charged_cents")
  clientPlanSubscriptionId Int?    @map("client_plan_subscription_id")
  planCreditConsumed       Boolean @default(false) @map("plan_credit_consumed")

  barbershop             Barbershop              @relation(fields: [barbershopId], references: [id])
  barber                 Barber                  @relation(fields: [barberId], references: [id])
  service                Service                 @relation(fields: [serviceId], references: [id])
  client                 Client                  @relation(fields: [clientId], references: [id])
  clientPlanSubscription ClientPlanSubscription? @relation(fields: [clientPlanSubscriptionId], references: [id])
  review                 Review?
  productSales           ProductSale[]

  @@index([barbershopId])
  @@index([barberId, date])
  @@map("appointments")
}

model User {
  id           Int      @id @default(autoincrement())
  barbershopId Int      @map("barbershop_id")
  barberId     Int?     @map("barber_id")
  role         UserRole
  username     String   @unique
  passwordHash String   @map("password_hash")
  name         String
  createdAt    DateTime @default(now()) @map("created_at")

  // Opcional a nível de schema (usuários do seed/demo não têm) mas exigido
  // pela rota de cadastro pra contas novas. Token de confirmação enviado por
  // e-mail no signup — nulo depois de verificado ou se nunca chegou a pedir.
  email                      String?   @unique
  emailVerifiedAt            DateTime? @map("email_verified_at")
  emailVerificationToken     String?   @unique @map("email_verification_token")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")

  // "Esqueci minha senha" — token separado do de verificação de e-mail (um
  // pedido de reset não pode invalidar um convite de verificação pendente,
  // e vice-versa).
  passwordResetToken     String?   @unique @map("password_reset_token")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")

  barbershop        Barbershop         @relation(fields: [barbershopId], references: [id])
  barber            Barber?            @relation(fields: [barberId], references: [id])
  pushSubscriptions PushSubscription[]

  @@index([barbershopId])
  @@map("users")
}

model TimeBlock {
  id           Int       @id @default(autoincrement())
  barbershopId Int       @map("barbershop_id")
  barberId     Int?      @map("barber_id")
  type         String
  label        String?
  date         DateTime? @db.Date
  startTime    String    @map("start_time")
  endTime      String    @map("end_time")
  recurring    Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id])
  barber     Barber?    @relation(fields: [barberId], references: [id])

  @@index([barbershopId])
  @@map("time_blocks")
}

model Review {
  id            Int      @id @default(autoincrement())
  appointmentId Int      @unique @map("appointment_id")
  barbershopId  Int      @map("barbershop_id")
  barberId      Int      @map("barber_id")
  clientId      Int      @map("client_id")
  rating        Int
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  barbershop  Barbershop  @relation(fields: [barbershopId], references: [id])
  barber      Barber      @relation(fields: [barberId], references: [id])
  client      Client      @relation(fields: [clientId], references: [id])

  @@index([barbershopId])
  @@map("reviews")
}

model Product {
  id                Int     @id @default(autoincrement())
  barbershopId      Int     @map("barbershop_id")
  name              String
  priceCents        Int     @map("price_cents")
  active            Boolean @default(true)
  stockQuantity     Int     @default(0) @map("stock_quantity")
  lowStockThreshold Int     @default(5) @map("low_stock_threshold")

  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id])
  productSales ProductSale[]

  @@index([barbershopId])
  @@map("products")
}

model ProductSale {
  id            Int      @id @default(autoincrement())
  barbershopId  Int      @map("barbershop_id")
  clientId      Int      @map("client_id")
  productId     Int      @map("product_id")
  quantity      Int      @default(1)
  date          DateTime @db.Date
  appointmentId Int?     @map("appointment_id")
  createdAt     DateTime @default(now()) @map("created_at")

  barbershop  Barbershop   @relation(fields: [barbershopId], references: [id])
  client      Client       @relation(fields: [clientId], references: [id])
  product     Product      @relation(fields: [productId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([barbershopId])
  @@map("product_sales")
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  barbershopId Int      @map("barbershop_id")
  userName     String   @map("user_name")
  action       String
  details      String?
  createdAt    DateTime @default(now()) @map("created_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id])

  @@index([barbershopId])
  @@map("audit_log")
}

model BusinessHours {
  id           Int     @id @default(autoincrement())
  barbershopId Int     @map("barbershop_id")
  weekday      Int
  opensAt      String  @map("opens_at")
  closesAt     String  @map("closes_at")
  closed       Boolean @default(false)

  barbershop Barbershop @relation(fields: [barbershopId], references: [id])

  @@unique([barbershopId, weekday])
  @@map("business_hours")
}

model Escalation {
  id           Int      @id @default(autoincrement())
  barbershopId Int      @map("barbershop_id")
  clientId     Int?     @map("client_id")
  clientPhone  String   @map("client_phone")
  reason       String
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id])
  client     Client?    @relation(fields: [clientId], references: [id])

  @@index([barbershopId])
  @@map("escalations")
}

model PushSubscription {
  id           Int      @id @default(autoincrement())
  barbershopId Int      @map("barbershop_id")
  userId       Int      @map("user_id")
  endpoint     String   @unique
  p256dh       String
  auth         String
  createdAt    DateTime @default(now()) @map("created_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id])
  user       User       @relation(fields: [userId], references: [id])

  @@index([barbershopId])
  @@map("push_subscriptions")
}

// Histórico de conversa do chat de IA, persistido no banco em vez de em
// memória do processo: em ambiente serverless (Vercel), duas mensagens
// consecutivas do mesmo cliente podem cair em instâncias diferentes, e um
// Map em memória perderia o contexto no meio da conversa (ex: o bot lista
// serviços numerados, e a próxima mensagem "1" chega numa instância sem
// memória da lista, então o bot não entende a resposta).
model ChatSession {
  sessionId    String   @id @map("session_id")
  barbershopId Int      @map("barbershop_id")
  messages     Json
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("chat_sessions")
}

// Deduplicação de mensagens do webhook do WhatsApp: a Meta reenvia o mesmo
// evento (com o mesmo "wamid") se nossa resposta demorar demais ou se der
// erro de rede — sem isso, o cliente receberia a mesma resposta da IA
// duplicada. Registros mais antigos que a janela de retry da Meta (7 dias)
// podem ser limpos, mas não há job de limpeza automática ainda.
model ProcessedWhatsappMessage {
  id          String   @id // wamid da mensagem, ex: "wamid.HBgLM..."
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("processed_whatsapp_messages")
}

// Backing dos rate limiters (login, chat, autoatendimento público) — em
// Postgres em vez de Map em memória, porque em serverless cada instância
// teria seu próprio Map e o limite não valeria nada na prática (mesmo bug
// que já mordeu o histórico de chat antes de virar chat_sessions no banco).
model RateLimitHit {
  id        Int      @id @default(autoincrement())
  key       String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([key, createdAt])
  @@map("rate_limit_hits")
}

// Placeholder para a próxima fase (billing/Stripe) — schema já preparado,
// sem lógica de cobrança implementada nesta passada.
model Subscription {
  id                   Int                @id @default(autoincrement())
  barbershopId         Int                @unique @map("barbershop_id")
  status               SubscriptionStatus @default(trialing)
  plan                 String             @default("starter")
  trialEndsAt          DateTime?          @map("trial_ends_at")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id])

  @@map("subscriptions")
}

// Planos de assinatura que a barbearia (não a plataforma) oferece pros
// próprios clientes finais — feature restrita ao plano Pro, cobrada via
// Stripe Connect (conta conectada da barbearia, ver stripeConnectAccountId
// em Barbershop). Benefício é um enum fechado (não motor de regras livre)
// pra manter self-service sem virar suporte manual.
model ClientPlan {
  id              Int                   @id @default(autoincrement())
  barbershopId    Int                   @map("barbershop_id")
  name            String
  priceCents      Int                   @map("price_cents")
  benefitType     ClientPlanBenefitType @map("benefit_type")
  benefitValue    Int                   @map("benefit_value")
  serviceId       Int?                  @map("service_id")
  active          Boolean               @default(true)
  stripeProductId String?               @map("stripe_product_id")
  stripePriceId   String?               @map("stripe_price_id")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  barbershop    Barbershop               @relation(fields: [barbershopId], references: [id])
  service       Service?                 @relation(fields: [serviceId], references: [id])
  subscriptions ClientPlanSubscription[]

  @@index([barbershopId])
  @@map("client_plans")
}

// Assinatura de um Client a um ClientPlan de uma barbearia específica —
// criada pelo webhook do Connect quando o checkout.session.completed chega,
// nunca diretamente pela rota de checkout (que só inicia a sessão).
model ClientPlanSubscription {
  id                   Int                          @id @default(autoincrement())
  barbershopId         Int                          @map("barbershop_id")
  clientId             Int                          @map("client_id")
  clientPlanId         Int                          @map("client_plan_id")
  status               ClientPlanSubscriptionStatus @default(active)
  stripeSubscriptionId String?                      @unique @map("stripe_subscription_id")
  stripeCustomerId     String?                      @map("stripe_customer_id")
  currentPeriodEnd     DateTime?                    @map("current_period_end")
  // Consumo do benefício "services_included" no ciclo atual — zerado a cada
  // renovação (customer.subscription.updated com período novo).
  usedThisPeriod       Int                          @default(0) @map("used_this_period")
  createdAt            DateTime                     @default(now()) @map("created_at")
  updatedAt            DateTime                     @updatedAt @map("updated_at")

  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id])
  client       Client        @relation(fields: [clientId], references: [id])
  clientPlan   ClientPlan    @relation(fields: [clientPlanId], references: [id])
  appointments Appointment[]

  @@unique([clientId, clientPlanId])
  @@index([barbershopId])
  @@index([clientId])
  @@map("client_plan_subscriptions")
}

// Código de verificação enviado por WhatsApp (Message Template categoria
// Authentication) antes do cliente conseguir assinar um plano — evita que
// um erro de digitação no telefone vincule a assinatura a um número errado.
model PhoneVerification {
  id         Int       @id @default(autoincrement())
  phone      String    @unique
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  attempts   Int       @default(0)
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("phone_verifications")
}
